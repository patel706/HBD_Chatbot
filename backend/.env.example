# Example environment variables for backend
# Copy this to .env and fill in your actual values
# Do NOT store real secrets here in version control

# Server Configuration
PORT=5000
FRONTEND_ORIGIN=http://localhost:3000
DATABASE_URL=businesses.db

# OpenRouter API Keys (LLM Integration)
# Multiple keys supported (comma-separated) for load balancing
OPEN_ROUTER_API_KEYS="your-api-key-1,your-api-key-2,your-api-key-3"

# MySQL Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=master

# Email Configuration (Gmail SMTP)
MAIL_USERNAME="your-email@gmail.com"
MAIL_PASSWORD="your-app-password"
MAIL_FROM="your-email@gmail.com"
MAIL_SERVER="smtp.gmail.com"
MAIL_PORT=587

# JWT Authentication
SECRET="your-super-secret-key-change-this"
ALGO="HS256"

# Redis Cache
REDIS_URL="redis://localhost:6379"
